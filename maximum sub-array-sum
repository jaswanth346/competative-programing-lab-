#include <iostream>
#include <cmath>
#include <cstdio>
#include <vector>
#include <algorithm>
using namespace std;

int main() {
    int n;
    cin >> n;
    vector<int> a(n);
    for (int i = 0; i < n; i++) {
        cin >> a[i];
    }
    int maxEndingHere = a[0];
    int maxSoFar = a[0];
    for (int i = 1; i < n; i++) {
        maxEndingHere = max(a[i], maxEndingHere + a[i]);
        maxSoFar = max(maxSoFar, maxEndingHere);
    }
    cout << maxSoFar;
    return 0;
}  
